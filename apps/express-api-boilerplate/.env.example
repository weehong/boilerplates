# Runtime environment: development | test | production
NODE_ENV="development"

# HTTP port the server listens on
PORT="3000"

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL="info"

# Allowed CORS origin(s). Use "*" for any, or a comma-separated list of origins.
CORS_ORIGIN="*"

# Rate limiter: window length (ms) and max requests per window per IP
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="100"

# Trust x-forwarded-* headers. Enable ("true") only when behind a trusted
# reverse proxy / load balancer; leave "false" when directly exposed.
TRUST_PROXY="false"

# PostgreSQL connection string used by Prisma. Required in production; falls
# back to this local instance in development/test if unset.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/express_api?schema=public"
