{
	"name": "express-api-boilerplate",
	"version": "0.0.0",
	"description": "Production-grade Express 5 + TypeScript API boilerplate with Prisma, pino, zod, and OpenAPI.",
	"type": "module",
	"private": true,
	"author": "Vernon Wee Hong KOH",
	"license": "MIT",
	"engines": {
		"node": ">=22"
	},
	"main": "dist/server.js",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"start": "node dist/server.js",
		"typecheck": "tsc --noEmit",
		"format": "prettier \"src/**/*.ts\" \"tests/**/*.ts\" \"e2e/**/*.ts\" --write",
		"lint": "eslint --max-warnings 0",
		"lint:fix": "eslint --max-warnings 0 --fix",
		"test": "vitest run && playwright test",
		"test:unit": "vitest",
		"test:unit:run": "vitest run",
		"test:unit:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:report": "playwright show-report",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"db:studio": "prisma studio",
		"commitlint": "commitlint --edit",
		"commitizen": "cz",
		"prepare": "husky",
		"setup": "npx husky init && npx playwright install"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "^7.3.0",
		"@prisma/client": "^6.2.1",
		"compression": "^1.7.5",
		"cors": "^2.8.5",
		"express": "^5.0.1",
		"express-rate-limit": "^7.5.0",
		"helmet": "^8.0.0",
		"pino": "^9.6.0",
		"pino-http": "^10.4.0",
		"swagger-ui-express": "^5.0.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.6.1",
		"@commitlint/config-conventional": "^19.6.0",
		"@eslint/js": "^9.18.0",
		"@types/compression": "^1.7.5",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/node": "^22.10.6",
		"@types/supertest": "^6.0.2",
		"@types/swagger-ui-express": "^4.1.7",
		"@playwright/test": "^1.49.1",
		"@typescript-eslint/eslint-plugin": "^8.20.0",
		"@typescript-eslint/parser": "^8.20.0",
		"@vitest/coverage-v8": "^2.1.8",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-unicorn": "^56.0.1",
		"globals": "^15.14.0",
		"husky": "^9.1.7",
		"pino-pretty": "^13.0.0",
		"prettier": "^3.4.2",
		"prisma": "^6.2.1",
		"supertest": "^7.0.0",
		"tsc-alias": "^1.8.10",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.20.0",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^2.1.8"
	}
}
