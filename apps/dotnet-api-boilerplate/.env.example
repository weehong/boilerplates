# Copy to .env and adjust. Used by compose.yml and (optionally) local runs.

# --- PostgreSQL ---
POSTGRES_USER=dotnet_api_boilerplate
POSTGRES_PASSWORD=change_me_in_real_environments
POSTGRES_DB=dotnet_api_boilerplate

# --- API ---
# ASP.NET Core picks this connection string up via ConnectionStrings__Default.
# NOTE: Host=db resolves ONLY inside the Docker Compose network (the postgres service is named "db").
# For local, non-Docker runs (dotnet run / make run) use Host=localhost instead, e.g.:
#   ConnectionStrings__Default=Host=localhost;Port=5432;Database=dotnet_api_boilerplate;Username=dotnet_api_boilerplate;Password=change_me_in_real_environments
ConnectionStrings__Default=Host=db;Port=5432;Database=dotnet_api_boilerplate;Username=dotnet_api_boilerplate;Password=change_me_in_real_environments
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_HTTP_PORTS=8080

# --- Container image ---
DOCKER_IMAGE=dotnet_api_boilerplate/api
IMAGE_TAG=latest
