# ──────────────────────────────────────────────
# Project
# ──────────────────────────────────────────────
# Drives container/image names in compose.yaml (must be lowercase).
PROJECT_NAME=spring_boot_boilerplate

# ──────────────────────────────────────────────
# API configuration
# ──────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=default

# ──────────────────────────────────────────────
# Swagger / OpenAPI
# ──────────────────────────────────────────────
SWAGGER_ENABLED=false

# ──────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────
TRACING_ENABLED=false
TRACING_SAMPLING_PROBABILITY=1.0

# ──────────────────────────────────────────────
# Database (Required)
# ──────────────────────────────────────────────
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5432
POSTGRES_DB_NAME=spring_boot_boilerplate
POSTGRES_DB_USER=postgres
POSTGRES_DB_PASS=change-me

# ──────────────────────────────────────────────
# Database Pool (Optional)
# ──────────────────────────────────────────────
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2
DB_IDLE_TIMEOUT=300000
DB_MAX_LIFETIME=1800000
DB_CONNECTION_TIMEOUT=30000
DB_LEAK_DETECTION=60000

# ──────────────────────────────────────────────
# Flyway
# ──────────────────────────────────────────────
FLYWAY_ENABLED=true

# ──────────────────────────────────────────────
# Redis / Cache
# ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
CACHE_TYPE=none

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
